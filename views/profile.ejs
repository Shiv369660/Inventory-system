<!-- Profile Page -->
<div class="max-w-2xl mx-auto">
  <div class="card mb-6">
    <div class="flex items-center gap-4 mb-6">
      <div class="w-16 h-16 rounded-2xl bg-primary flex items-center justify-center">
        <span class="text-2xl font-bold text-white"><%= profile.name.charAt(0).toUpperCase() %></span>
      </div>
      <div>
        <h3 class="text-xl font-bold"><%= profile.name %></h3>
        <p class="text-sm text-txt/50"><%= profile.email %></p>
        <span class="badge badge-info mt-1"><%= profile.role %></span>
      </div>
    </div>
    <div class="border-t border-border pt-4">
      <p class="text-xs text-txt/40">Member since <%= new Date(profile.created_at).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' }) %></p>
    </div>
  </div>

  <!-- Edit Profile -->
  <div class="card mb-6">
    <h4 class="font-semibold mb-4 flex items-center gap-2"><i data-lucide="edit" class="w-4 h-4 text-primary"></i> Edit Profile</h4>
    <form id="profileForm" class="space-y-4">
      <div><label class="block text-xs font-medium mb-1">Name</label><input type="text" id="profName" class="form-input" value="<%= profile.name %>" required></div>
      <div><label class="block text-xs font-medium mb-1">Email</label><input type="email" id="profEmail" class="form-input" value="<%= profile.email %>" required></div>
      <button type="submit" class="btn btn-primary">Update Profile</button>
    </form>
  </div>

  <!-- Change Password -->
  <div class="card">
    <h4 class="font-semibold mb-4 flex items-center gap-2"><i data-lucide="lock" class="w-4 h-4 text-primary"></i> Change Password</h4>
    <form id="pwForm" class="space-y-4">
      <div><label class="block text-xs font-medium mb-1">Current Password</label><input type="password" id="curPw" class="form-input" required></div>
      <div><label class="block text-xs font-medium mb-1">New Password</label><input type="password" id="newPw" class="form-input" required minlength="6"></div>
      <button type="submit" class="btn btn-secondary">Change Password</button>
    </form>
  </div>
</div>

<script>
document.getElementById('profileForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  try { await apiFetch('/profile/api', { method: 'POST', body: JSON.stringify({ name: document.getElementById('profName').value, email: document.getElementById('profEmail').value })}); showToast('Profile updated!'); setTimeout(() => location.reload(), 1000); } catch(e) {}
});
document.getElementById('pwForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  try { await apiFetch('/profile/api/password', { method: 'POST', body: JSON.stringify({ currentPassword: document.getElementById('curPw').value, newPassword: document.getElementById('newPw').value })}); showToast('Password changed!'); document.getElementById('pwForm').reset(); } catch(e) {}
});
lucide.createIcons();
</script>
