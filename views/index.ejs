            <div class="w-20 h-20 mx-auto rounded-2xl bg-white shadow-lg border border-gray-100 flex items-center justify-center transition-transform duration-200 hover:scale-105">
              <i data-lucide="bot" class="w-10 h-10 text-primary"></i>
