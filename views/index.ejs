  <!-- Lucide icons — loaded last, non-blocking -->
  <script src="https://unpkg.com/lucide@latest" defer></script>
  <script>
    // Wait for lucide to be available (defer ordering isn't guaranteed cross-CDN)
    function initLucide() {
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
        initPage();
      } else {
        requestAnimationFrame(initLucide);
      }
    }

    function initPage() {
      // ── 1. Hero badge fade-in ──────────────────────────────────────────
      // Tiny delay so it pops in after the page settles — feels intentional
      const badge = document.getElementById('hero-badge');
      if (badge) {
        requestAnimationFrame(() => {
          badge.style.transition = 'opacity 400ms cubic-bezier(0.23,1,0.32,1), transform 400ms cubic-bezier(0.23,1,0.32,1)';
          badge.style.transform = 'translateY(4px)';
          setTimeout(() => {
            badge.style.opacity = '1';
            badge.style.transform = 'translateY(0)';
          }, 300);
        });
      }

      // ── 2. Hero animation — triggered once after first paint ──────────
      const heroText  = document.querySelector('.hero-text');
      const heroImage = document.querySelector('.hero-image');
      if (heroText)  heroText.classList.add('animate');
      if (heroImage) heroImage.classList.add('animate');

      // ── 3. Scroll-reveal via IntersectionObserver ──────────────────────
      // Vercel pattern: defer DOM work until elements are actually needed
      const revealObs = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            revealObs.unobserve(entry.target); // Early exit — observe once
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('[data-reveal], [data-reveal-stagger]').forEach(el => {
        revealObs.observe(el);
      });

      // ── 4. Navbar scroll effect ───────────────────────────────────────
      const navbar = document.getElementById('navbar');
      let lastScrollY = 0;
      const onScroll = () => {
        const y = window.scrollY;
        navbar.classList.toggle('navbar-scrolled', y > 20);
        // Active nav link highlight based on scroll section
        const sections = ['features', 'workflow', 'demo'];
        // Build index map once — O(1) lookups (Vercel js-index-maps pattern)
        sections.forEach(id => {
          const el = document.getElementById(id);
          if (!el) return;
          const rect = el.getBoundingClientRect();
          const navLink = document.querySelector(`[data-nav-section="${id}"]`);
          if (!navLink) return;
          const active = rect.top <= 120 && rect.bottom > 120;
          navLink.classList.toggle('text-primary', active);
          navLink.classList.toggle('text-muted', !active);
        });
        lastScrollY = y;
      };
      window.addEventListener('scroll', onScroll, { passive: true });

      // ── 5. Mobile menu toggle ─────────────────────────────────────────
      const mobileBtn  = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      if (mobileBtn && mobileMenu) {
        mobileBtn.addEventListener('click', () => {
          const open = mobileMenu.classList.toggle('hidden') === false;
          mobileBtn.setAttribute('aria-expanded', String(open));
          // Re-run lucide icons in case menu was previously hidden
          lucide.createIcons();
        });
        // Close on link click
        mobileMenu.querySelectorAll('a').forEach(a => {
          a.addEventListener('click', () => mobileMenu.classList.add('hidden'));
        });
      }

      // ── 6. Live demo clock ────────────────────────────────────────────
      const demoClock = document.getElementById('demo-clock');
      if (demoClock) {
        const updateDemoClock = () => {
          demoClock.textContent = new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
        };
        updateDemoClock();
        setInterval(updateDemoClock, 1000);
      }

      // ── 7. Animated stat counters ─────────────────────────────────────
      // Use IntersectionObserver — only animate when visible (Vercel pattern)
      const statEls = document.querySelectorAll('.stat-number[data-target]');
      if (statEls.length > 0) {
        const statObs = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            const el     = entry.target;
            const target = parseInt(el.dataset.target, 10);
            const suffix = el.textContent.replace(/\d+/, '').trim(); // preserve +, %, h
            let start    = 0;
            const dur    = 1200; // ms
            const startT = performance.now();
            const tick = (now) => {
              const progress = Math.min((now - startT) / dur, 1);
              // ease-out cubic — starts fast, decelerates (same philosophy as CSS)
              const eased = 1 - Math.pow(1 - progress, 3);
              el.textContent = Math.round(eased * target) + suffix;
              if (progress < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
            statObs.unobserve(el); // Early exit — animate once
          });
        }, { threshold: 0.5 });
        statEls.forEach(el => statObs.observe(el));
      }
    }

    // Bootstrap: lucide might already be loaded or still loading
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLucide);
    } else {
      initLucide();
    }
  </script>

</body>

</html>