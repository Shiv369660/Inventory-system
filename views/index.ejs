          <h3 class="text-xl font-bold text-text mb-3">Add Your Products</h3>
          <p class="text-muted leading-relaxed text-sm">
            Create products with SKU, categories, and initial stock levels. Set minimum thresholds for automatic alerts.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="workflow-step text-center relative">
          <div class="hidden md:block absolute top-10 left-[60%] w-[80%] h-0.5 bg-gradient-to-r from-primary/30 to-transparent" aria-hidden="true"></div>
          <div class="relative mb-8">
