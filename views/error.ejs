<div class="flex items-center justify-center min-h-[60vh]">
  <div class="text-center">
    <div class="w-16 h-16 rounded-2xl bg-danger/10 mx-auto flex items-center justify-center mb-4">
      <i data-lucide="alert-triangle" class="w-8 h-8 text-danger"></i>
    </div>
    <h1 class="text-2xl font-bold mb-2">Something went wrong</h1>
