<!-- Deliveries Page -->
<div class="flex justify-between items-center mb-6">
  <div><h3 class="text-lg font-semibold">Deliveries (Outgoing Stock)</h3><p class="text-sm text-txt/50">Track goods leaving warehouse</p></div>
  <button onclick="openModal('deliveryModal')" class="btn btn-primary"><i data-lucide="plus" class="w-4 h-4"></i> New Delivery</button>
</div>

<div class="card">
  <div class="overflow-x-auto">
    <table class="data-table">
      <thead><tr><th>Reference</th><th>Customer</th><th>Items</th><th>Total Qty</th><th>Status</th><th>Date</th><th>Actions</th></tr></thead>
      <tbody>
        <% if (deliveries.length === 0) { %><tr><td colspan="7" class="text-center py-8 text-txt/40">No deliveries yet</td></tr><% } %>
        <% deliveries.forEach(function(d) { %>
        <tr>
          <td class="font-mono font-medium text-sm"><%= d.reference %></td>
          <td><%= d.customer %></td>
          <td><%= d.line_count %></td>
          <td class="font-semibold"><%= parseFloat(d.total_qty) %></td>
          <td><span class="badge badge-<%= d.status === 'validated' ? 'validated' : 'draft' %>"><%= d.status %></span></td>
          <td class="text-sm text-txt/50"><%= new Date(d.created_at).toLocaleDateString() %></td>
          <td>
            <% if (d.status === 'draft') { %>
            <button onclick="validateDelivery(<%= d.id %>)" class="btn btn-success btn-sm"><i data-lucide="check" class="w-3 h-3"></i> Validate</button>
            <% } else { %><span class="text-xs text-txt/40">Completed</span><% } %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<div id="deliveryModal" class="modal-overlay hidden">
  <div class="modal-content">
    <div class="flex items-center justify-between mb-6">
      <h3 class="text-lg font-bold">New Delivery Order</h3>
      <button onclick="closeModal('deliveryModal')" class="p-1 hover:bg-surface rounded-lg"><i data-lucide="x" class="w-5 h-5"></i></button>
    </div>
    <form id="deliveryForm" class="space-y-4">
      <div><label class="block text-xs font-medium mb-1">Customer *</label><input type="text" id="dCustomer" class="form-input" required></div>
      <div><label class="block text-xs font-medium mb-1">Notes</label><input type="text" id="dNotes" class="form-input"></div>
      <div>
        <label class="block text-xs font-medium mb-2">Product Lines</label>
        <div id="deliveryLines" class="space-y-2"></div>
        <button type="button" onclick="addDeliveryLine()" class="btn btn-secondary btn-sm mt-2"><i data-lucide="plus" class="w-3 h-3"></i> Add Line</button>
      </div>
      <div class="flex justify-end gap-2 pt-2">
        <button type="button" onclick="closeModal('deliveryModal')" class="btn btn-secondary">Cancel</button>
        <button type="submit" class="btn btn-primary">Create Delivery</button>
      </div>
    </form>
  </div>
</div>

<script>
const products = <%- JSON.stringify(products) %>;
function addDeliveryLine() {
  const div = document.createElement('div');
  div.className = 'flex gap-2 items-center';
  div.innerHTML = `<select class="form-input flex-1 dl-product" required>${products.map(p => `<option value="${p.id}">${p.name} (${p.sku}) — Stock: ${p.current_stock}</option>`).join('')}</select>
    <input type="number" class="form-input w-24 dl-qty" placeholder="Qty" min="1" value="1" required>
    <button type="button" onclick="this.parentElement.remove()" class="btn btn-danger btn-sm"><i data-lucide="x" class="w-3 h-3"></i></button>`;
  document.getElementById('deliveryLines').appendChild(div);
  lucide.createIcons();
}
addDeliveryLine();

document.getElementById('deliveryForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const lines = [...document.querySelectorAll('#deliveryLines > div')].map(d => ({
    product_id: parseInt(d.querySelector('.dl-product').value),
    quantity: parseFloat(d.querySelector('.dl-qty').value)
  }));
  try {
    await apiFetch('/deliveries/api', { method: 'POST', body: JSON.stringify({
      customer: document.getElementById('dCustomer').value,
      notes: document.getElementById('dNotes').value, lines
    })});
    showToast('Delivery order created!');
    setTimeout(() => location.reload(), 500);
  } catch(e) {}
});

async function validateDelivery(id) {
  if (!confirm('Validate this delivery? Stock will be decremented.')) return;
  try { await apiFetch('/deliveries/api/' + id + '/validate', { method: 'POST' }); showToast('Delivery validated! Stock updated.'); setTimeout(() => location.reload(), 500); } catch(e) {}
}
lucide.createIcons();
</script>
